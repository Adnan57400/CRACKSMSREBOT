# ═══════════════════════════════════════════════════════════
# CRACK SMS BOT — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# TELEGRAM BOT SETTINGS
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=CrackSMSReBot
DEVELOPER=@NONEXPERTCODER
SUPPORT_USER=@ownersigma

# ADMIN SETTINGS
INITIAL_ADMIN_IDS=7763727542,7057157722,7968271742,7831921606,8222195948

# CHANNEL & COMMUNITY LINKS
CHANNEL_LINK=https://t.me/crackotp
OTP_GROUP_LINK=https://t.me/crackotpgroup
NUMBER_BOT_LINK=https://t.me/CrackSMSReBot
GET_NUMBER_URL=https://t.me/CrackSMSReBot

# DATABASE SETTINGS
DATABASE_URL=sqlite:///./sms_database_np.db
DB_ECHO=false

# OTP SETTINGS
DEFAULT_ASSIGN_LIMIT=4
OTP_VALIDITY_HOURS=24
OTP_STORAGE_FILE=otp_store.json
OTP_GUI_THEME=0

# PANEL SETTINGS
API_FETCH_INTERVAL=1
API_MAX_RECORDS=200
DEFAULT_API_TIMEOUT=30

# COOLDOWN SETTINGS
CHANGE_COOLDOWN_S=7
RETENTION_HOURS=12

# CHILD BOT SETTINGS
IS_CHILD_BOT=false
CHILD_BOT_FORWARD_URL=

# DEPLOYMENT SETTINGS
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# FEATURE FLAGS
AUTO_BROADCAST_ON=false
ENABLE_ANALYTICS=true
ENABLE_WEBHOOKS=true
ENABLE_SCHEDULING=true

# PREMIUM TIER SETTINGS
ENABLE_PREMIUM=true
FREE_USERS_MAX_PANELS=2
PRO_USERS_MAX_PANELS=10
ENTERPRISE_USERS_MAX_PANELS=50

# API SETTINGS
API_RATE_LIMIT=100
API_RATE_WINDOW=60

# TIMEZONE
TIMEZONE=UTC

# LOGGING
LOG_FILE=bot.log
MAX_LOG_SIZE=10485760
LOG_BACKUP_COUNT=5

# PERFORMANCE
MAX_WORKERS=4
ASYNC_TIMEOUT=30
CONNECTION_POOL_SIZE=10
